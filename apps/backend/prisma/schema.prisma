generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum PermissionScope {
  PLATFORM
  ORGANIZATION
}

enum RoleMembershipScope {
  TEAM
  ORGANIZATION
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATION
  WON
  LOST
  SITE_VISIT_COMPLETED
  VISIT_SCHEDULED
}

enum ActivityType {
  CALL
  EMAIL
  OFFLINE_MEETING
  NOTE
  ONLINE_MEETING
  SITE_VISIT
  MESSAGE
}

enum NotificationType {
  LEAD_CREATED
  LEAD_ASSIGNED
  LEAD_REASSIGNED
  LEAD_STATUS_CHANGED
  ACTIVITY_LOGGED
  WELCOME_CHANGE_PASSWORD
}

enum ModuleKey {
  SALES_ERP
  DASHBOARDS
  NOTIFICATIONS
}

enum AuditAction {
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILED
  AUTH_LOGOUT
  AUTH_TOKEN_REFRESHED
  AUTH_TOKEN_REFRESH_FAILED
  AUTH_SESSION_REVOKED
  AUTH_PROFILE_UPDATED
  AUTH_PASSWORD_CHANGED
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_STATUS_CHANGED
  LEAD_ASSIGNED
  LEAD_REASSIGNED
  LEAD_UNASSIGNED
  ACTIVITY_LOGGED
  USER_CREATED
  USER_ACTIVATED
  USER_DEACTIVATED
  TEAM_CREATED
  TEAM_MEMBER_ADDED
  ROLE_CREATED
  ROLE_UPDATED
  ROLE_DELETED
  ORG_CREATED
  ORG_UPDATED
  ORG_STATUS_CHANGED
  ORG_MODULES_UPDATED
  PLATFORM_USER_CREATED
}

model Organization {
  id          String             @id @default(uuid())
  name        String
  code        String             @unique
  logoUrl     String?            @map("logo_url")
  description String?
  status      OrganizationStatus @default(ACTIVE)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  members         OrganizationMember[]
  roles           Role[]
  teams           Team[]
  leads           Lead[]
  notifications   Notification[]
  modules         OrganizationModule[]
  auditLogs       AuditLog[]

  @@map("organizations")
}

model OrganizationModule {
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleKey      ModuleKey    @map("module_key")
  enabled        Boolean      @default(true)
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@id([organizationId, moduleKey])
  @@map("organization_modules")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  name                String
  phoneNumber         String?             @map("phone_number")
  passwordHash        String              @map("password_hash")
  mustChangePassword  Boolean             @default(false) @map("must_change_password")
  status              UserStatus          @default(ACTIVE)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  userRole            UserRoleAssignment?
  memberships         OrganizationMember[]
  teamMembers         TeamMember[]
  createdLeads        Lead[]              @relation("LeadCreatedBy")
  assignedLeads       Lead[]              @relation("LeadAssignedTo")
  activities          Activity[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]
  dashboardLayout     UserDashboardLayout?

  @@map("users")
}

model OrganizationMember {
  userId         String     @map("user_id")
  organizationId String     @map("organization_id")
  roleId         String     @map("role_id")
  status         UserStatus @default(ACTIVE)
  joinedAt       DateTime   @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  teamMember   TeamMember?

  @@id([userId, organizationId])
  @@index([organizationId])
  @@index([roleId])
  @@map("organization_members")
}

model UserDashboardLayout {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  view      String
  widgets   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_dashboard_layouts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Role {
  id             String               @id @default(uuid())
  organizationId String?              @map("organization_id")
  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  membershipScope RoleMembershipScope @map("membership_scope")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  permissions    RolePermission[]
  userRoles      UserRoleAssignment[]
  members        OrganizationMember[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  key              String           @id
  label            String
  description      String?
  scope            PermissionScope
  rolePermissions  RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId        String     @map("role_id")
  permissionKey String     @map("permission_key")
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Restrict)

  @@id([roleId, permissionKey])
  @@map("role_permissions")
}

model UserRoleAssignment {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@unique([userId])
  @@map("user_roles")
}

model Team {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  members        TeamMember[]
  leads          Lead[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMember {
  teamId         String @map("team_id")
  userId         String @map("user_id")
  organizationId String @map("organization_id")
  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership     OrganizationMember @relation(fields: [userId, organizationId], references: [userId, organizationId], onDelete: Cascade)

  @@id([teamId, userId])
  @@unique([userId, organizationId])
  @@index([userId])
  @@map("team_members")
}

model Lead {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId         String     @map("team_id")
  team           Team       @relation(fields: [teamId], references: [id], onDelete: Restrict)
  assignedToId   String?    @map("assigned_to_id")
  assignedTo     User?      @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  name           String
  mobileNumber   String?    @map("mobile_number")
  email          String?
  source         String?
  project        String?
  status         LeadStatus @default(NEW)
  createdById    String     @map("created_by_id")
  createdBy      User       @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  activities     Activity[]

  @@index([organizationId])
  @@index([teamId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Activity {
  id          String       @id @default(uuid())
  leadId      String       @map("lead_id")
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        ActivityType
  notes       String
  createdById String       @map("created_by_id")
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@map("activities")
}

model Notification {
  id             String            @id @default(uuid())
  organizationId String?           @map("organization_id")
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userId         String            @map("user_id")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  title          String
  body           String
  entityType     String?           @map("entity_type")
  entityId       String?           @map("entity_id")
  readAt         DateTime?         @map("read_at")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([organizationId])
  @@index([userId, organizationId, readAt])
  @@map("notifications")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorId        String?      @map("actor_id")
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action         AuditAction
  entityType     String       @map("entity_type")
  entityId       String?      @map("entity_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
